# URL base de la API. Por defecto VACÍA = mismo origen (rutas relativas /api/...).
#   - Producción: el reverse proxy (Caddy) enruta /api al backend -> dejar vacío.
#   - Desarrollo: el proxy de Vite enruta /api -> dejar vacío.
# Solo definir esto si necesitas apuntar a una API en otro origen.
# VITE_API_BASE_URL=

# Destino del proxy de Vite en desarrollo (a dónde reenviar /api).
# Por defecto http://localhost:5152
# VITE_API_TARGET=http://localhost:5152
